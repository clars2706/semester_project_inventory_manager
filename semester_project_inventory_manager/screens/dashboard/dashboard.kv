#:kivy 1.0

<DashboardScreen>:
    name: 'dashboard'
    
    BoxLayout:
        orientation: 'horizontal'
        # Sidebar
        BoxLayout:
            id: sidebar
            orientation: 'vertical'
            size_hint_x: 0.22 if root.sidebar_open else None
            width: 200 if root.sidebar_open else 0
            minimum_width: 0
            opacity: 1 if root.sidebar_open else 0
            canvas.before:
                Color:
                    rgba: (0.15, 0.2, 0.3, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: 'Close'
                size_hint_y: None
                height: '30dp'  # 25% less than 40dp
                on_press: root.toggle_sidebar()
            GridLayout:
                cols: 1
                spacing: 15
                size_hint_y: 0.7
                Button:
                    text: 'Add New Item'
                    font_size: '16sp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.manager.current = 'item_add'
                    size_hint_y: None
                    height: '36dp'  # 25% less than 48dp (default)
                Button:
                    text: 'Manage Inventory'
                    font_size: '16sp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.manager.current = 'item_manager'
                    size_hint_y: None
                    height: '36dp'
                Button:
                    text: 'View Reports'
                    font_size: '16sp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.manager.current = 'reports'
                    size_hint_y: None
                    height: '36dp'
                Button:
                    text: 'More Options'
                    font_size: '16sp'
                    background_color: (0.7, 0.7, 0.7, 1)
                    on_press: root.show_menu()
                    size_hint_y: None
                    height: '36dp'
        # Main content
        BoxLayout:
            orientation: 'vertical'
            padding: 20
            spacing: 20
            # Top bar with profile/settings
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: self.height * 0.10 if self.height else 60
                spacing: 10
                Widget:
                Button:
                    text: 'Profile/Settings'
                    size_hint_x: None
                    width: self.height * 2 if self.height else 120
                    on_press: app.open_settings() if hasattr(app, 'open_settings') else None
            # Summary cards
            GridLayout:
                cols: 4
                size_hint_y: None
                height: self.parent.height * 0.18 if self.parent else 120
                spacing: 15
                canvas.before:
                    Color:
                        rgba: (0.95, 0.95, 0.95, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    orientation: 'vertical'
                    padding: 10
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.6, 0.8, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        text: 'Total Items'
                        font_size: self.height * 0.18 if self.height else 18
                        color: (1,1,1,1)
                    Label:
                        text: '1234'  # Replace with dynamic value
                        font_size: self.height * 0.32 if self.height else 32
                        bold: True
                        color: (1,1,1,1)
                BoxLayout:
                    orientation: 'vertical'
                    padding: 10
                    canvas.before:
                        Color:
                            rgba: (0.9, 0.5, 0.2, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        text: 'Low Stock'
                        font_size: self.height * 0.18 if self.height else 18
                        color: (1,1,1,1)
                    Label:
                        text: '12'  # Replace with dynamic value
                        font_size: self.height * 0.32 if self.height else 32
                        bold: True
                        color: (1,1,1,1)
                BoxLayout:
                    orientation: 'vertical'
                    padding: 10
                    canvas.before:
                        Color:
                            rgba: (0.7, 0.2, 0.2, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        text: 'Out of Stock'
                        font_size: self.height * 0.18 if self.height else 18
                        color: (1,1,1,1)
                    Label:
                        text: '3'  # Replace with dynamic value
                        font_size: self.height * 0.32 if self.height else 32
                        bold: True
                        color: (1,1,1,1)
                BoxLayout:
                    orientation: 'vertical'
                    padding: 10
                    canvas.before:
                        Color:
                            rgba: (0.3, 0.7, 0.3, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        text: 'Categories'
                        font_size: self.height * 0.18 if self.height else 18
                        color: (1,1,1,1)
                    Label:
                        text: '8'  # Replace with dynamic value
                        font_size: self.height * 0.32 if self.height else 32
                        bold: True
                        color: (1,1,1,1)
            # Quick Add and Low Stock Alerts
            BoxLayout:
                orientation: 'horizontal'
                spacing: 20
                size_hint_y: None
                height: self.parent.height * 0.13 if self.parent else 80
                Button:
                    text: '+ Quick Add Item'
                    font_size: self.height * 0.35 if self.height else 18
                    size_hint_x: None
                    width: self.height * 2 if self.height else 120
                    background_color: (0.2, 0.6, 0.8, 1)
                    color: (1,1,1,1)
                    on_press: root.manager.current = 'item_add'
                BoxLayout:
                    orientation: 'vertical'
                    padding: 10
                    canvas.before:
                        Color:
                            rgba: (1, 0.9, 0.7, 1)
                        Rectangle:
                            pos: self.pos
                            size: self.size
                    Label:
                        text: 'Low Stock Alerts'
                        font_size: self.height * 0.22 if self.height else 16
                        color: (0.7,0.2,0.2,1)
                        bold: True
                    Label:
                        text: 'Item A, Item B, Item C'  # Replace with dynamic values
                        font_size: self.height * 0.18 if self.height else 14
                        color: (0.2,0.2,0.2,1)
            # Recent Activity
            BoxLayout:
                orientation: 'vertical'
                padding: 10
                spacing: 10
                canvas.before:
                    Color:
                        rgba: (0.97, 0.97, 1, 1)
                    Rectangle:
                        pos: self.pos
                        size: self.size
                Label:
                    text: 'Recent Activity'
                    font_size: self.height * 0.13 if self.height else 18
                    color: (0.1,0.4,0.7,1)
                    bold: True
                GridLayout:
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    row_default_height: 32
                    spacing: 5
                    Label:
                        text: 'Added 10 units to Item A'
                        font_size: 14
                        color: (0.2,0.2,0.2,1)
                    Label:
                        text: 'Removed 2 units from Item B'
                        font_size: 14
                        color: (0.2,0.2,0.2,1)
                    Label:
                        text: 'Edited Item C details'
                        font_size: 14
                        color: (0.2,0.2,0.2,1)
                
        
 