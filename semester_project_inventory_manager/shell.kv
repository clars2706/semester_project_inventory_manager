#:kivy 1.0

<AppShell>:
    orientation: 'vertical'
    screen_manager: screen_manager
    tabs: tabs

    # Top bar
    BoxLayout:
        orientation: 'horizontal'
        size_hint: (1, None)
        height: '60dp'
        padding: (10, 10)
        spacing: 10
        canvas.before:
            Color:
                rgba: (0.1, 0.4, 0.7, 1)
            Rectangle:
                size: self.size
                pos: self.pos

        Button:
            text: '☰'
            size_hint: None, None
            size: '40dp', '40dp'
            background_color: (0, 0, 0, 0)
            color: (1, 1, 1, 1)
            font_size: '22sp'
            on_press: root.toggle_sidebar()

        Label:
            text: "[b]Inventory Manager[/b]"
            font_size: '20sp'
            markup: True
            color: (1, 1, 1, 1)
            text_size: self.size
            halign: 'left'
            valign: 'middle'

    # Sidebar + screens
    BoxLayout:
        orientation: 'horizontal'

        # Sidebar
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: None
            width: 200 if root.sidebar_open else 0
            opacity: 1 if root.sidebar_open else 0
            canvas.before:
                Color:
                    rgba: (0.15, 0.2, 0.3, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: 'Close'
                size_hint_y: None
                height: '40dp'
                on_press: root.toggle_sidebar()

            BoxLayout:
                orientation: 'vertical'
                padding: '12dp', '8dp'
                spacing: '12dp'
                size_hint_y: None
                height: self.minimum_height

                Button:
                    text: 'Dashboard'
                    font_size: '14sp'
                    size_hint_y: None
                    height: '44dp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.change_screen('dashboard')
                Button:
                    text: 'Add New Item'
                    font_size: '14sp'
                    size_hint_y: None
                    height: '44dp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.change_screen('item_add')
                Button:
                    text: 'Manage Inventory'
                    font_size: '14sp'
                    size_hint_y: None
                    height: '44dp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.change_screen('item_manager')
                Button:
                    text: 'View Reports'
                    font_size: '14sp'
                    size_hint_y: None
                    height: '44dp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.change_screen('reports')

            Widget:
                size_hint_y: 1

        # All screens
        WindowManager:
            id: screen_manager

            DashboardScreen:
                name: 'dashboard'

            ItemAddScreen:
                name: 'item_add'

            ItemManagerScreen:
                name: 'item_manager'

            ReportsScreen:
                name: 'reports'

    # Tab bar
    BoxLayout:
        orientation: 'horizontal'
        size_hint: (1, None)
        height: '60dp'
        id: tabs
        spacing: 5
        padding: (5, 5)
        canvas.before:
            Color:
                rgba: (0.95, 0.95, 0.95, 1)
            Rectangle:
                size: self.size
                pos: self.pos

        TabButton:
            text: 'Dashboard'
            route: 'dashboard'
            is_active: True

        TabButton:
            text: 'Add Item'
            route: 'item_add'

        TabButton:
            text: 'Manage'
            route: 'item_manager'

        TabButton:
            text: 'Reports'
            route: 'reports'


<TabButton@Button>:
    route: ''
    is_active: False
    on_press: app.root.change_screen(self.route)

    canvas.before:
        Color:
            rgba: (0.2, 0.6, 0.8, 1) if self.is_active else (0.7, 0.7, 0.7, 1)
        Rectangle:
            size: self.size
            pos: self.pos
