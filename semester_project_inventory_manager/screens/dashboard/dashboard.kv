#:kivy 1.0

<DashboardScreen>:
    name: 'dashboard'

    BoxLayout:
        orientation: 'vertical'
        padding: '10dp'
        spacing: '10dp'

        # Header
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '60dp'
            canvas.before:
                Color:
                    rgba: (0.1, 0.4, 0.7, 1)
                Rectangle:
                    size: self.size
                    pos: self.pos

            Label:
                text: 'Inventory Manager'
                font_size: '24sp'
                bold: True
                color: (1, 1, 1, 1)
                text_size: self.size
                halign: 'left'
                valign: 'middle'
                padding: 10, 0

            Button:
                text: 'Profile / Settings'
                size_hint: None, None
                size: '140dp', '40dp'
                font_size: '13sp'
                background_color: (0.18, 0.48, 0.85, 1)
                on_press: root.show_settings()

        # Quick Add Item button
        Button:
            text: '+ Quick Add Item'
            font_size: '16sp'
            size_hint_y: None
            height: '52dp'
            background_color: (0.15, 0.7, 0.35, 1)
            color: (1, 1, 1, 1)
            on_press: root.show_quick_add()

        # Low Stock Alerts section
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: '4dp'
            padding: '10dp', '8dp'
            canvas.before:
                Color:
                    rgba: (1, 0.94, 0.94, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: '⚠  Low Stock Alerts'
                font_size: '15sp'
                bold: True
                color: (0.75, 0.1, 0.1, 1)
                size_hint_y: None
                height: '34dp'
                text_size: self.size
                halign: 'left'

            GridLayout:
                id: low_stock_grid
                cols: 3
                size_hint_y: None
                height: self.minimum_height
                spacing: '2dp'

        # Recent Activity section
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            spacing: '4dp'
            padding: '10dp', '8dp'
            canvas.before:
                Color:
                    rgba: (0.94, 0.96, 1, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: 'Recent Activity'
                font_size: '15sp'
                bold: True
                color: (0.1, 0.3, 0.65, 1)
                size_hint_y: None
                height: '34dp'
                text_size: self.size
                halign: 'left'

            GridLayout:
                id: activity_grid
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: '2dp'

        Widget:
