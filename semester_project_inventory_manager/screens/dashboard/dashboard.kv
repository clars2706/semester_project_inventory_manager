#:kivy 1.0

<DashboardScreen>:
    name: 'dashboard'
    
    BoxLayout:
        orientation: 'horizontal'
        # Sidebar
        BoxLayout:
            id: sidebar
            orientation: 'vertical'
            size_hint_x: None
            width: 200 if root.sidebar_open else 0
            opacity: 1 if root.sidebar_open else 0
            canvas.before:
                Color:
                    rgba: (0.15, 0.2, 0.3, 1)
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: 'Close'
                size_hint_y: None
                height: '40dp'
                on_press: root.toggle_sidebar()
            
            GridLayout:
                cols: 1
                spacing: 20
                size_hint_y: 0.7
                Button:
                    text: 'Add New Item'
                    font_size: '16sp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.manager.current = 'item_add'
                Button:
                    text: 'Manage Inventory'
                    font_size: '16sp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.manager.current = 'item_manager'
                Button:
                    text: 'View Reports'
                    font_size: '16sp'
                    background_color: (0.2, 0.6, 0.8, 1)
                    on_press: root.manager.current = 'reports'
                Button:
                    text: 'More Options'
                    font_size: '16sp'
                    background_color: (0.7, 0.7, 0.7, 1)
                    on_press: root.show_menu()
        # Main content
        BoxLayout:
            orientation: 'vertical'
            padding: 20
            spacing: 20
            # Toggle sidebar button (hamburger)
            Button:
                text: '\u2630'  # Unicode hamburger
                size_hint: None, None
                size: '40dp', '40dp'
                pos_hint: {'top': 1, 'x': 0}
                on_press: root.toggle_sidebar()
            # Header
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: '100dp'
                spacing: 10
                canvas.before:
                    Color:
                        rgba: (0.1, 0.4, 0.7, 1)
                    Rectangle:
                        size: self.size
                        pos: self.pos
                Label:
                    text: "Report Page"
                    font_size: '32sp'
                    bold: True
                    color: (1,1,1,1)
                    size_hint_y_: 0.6
                Label:
                    text: 'Titan Inventory Manager'
                    font_size: '32sp'
                    bold: True
                    color: (1, 1, 1, 1)
                    size_hint_y: 0.6
                Label:
                    text: 'Dashboard'
                    font_size: '16sp'
                    color: (1, 1, 1, 0.8)
                    size_hint_y: 0.4
            # Main content area
            BoxLayout:
                orientation: 'vertical'
                spacing: 20
                # Welcome message
                
                Label:
                    text: 'Select an option from the menu below to get started'
                    font_size: '14sp'
                    color: (0.5, 0.5, 0.5, 1)
                    size_hint_y: 0.1
                # Quick action buttons
                
        
 